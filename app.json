{
  "expo": {
    "name": "EquiMood",
    "slug": "EquiMood",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ce_que_tu_ressens_2.png",
    "scheme": "equimood",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emiliecolli.EquiMood",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "EquiMood te permet de choisir une photo depuis ta galerie pour personnaliser ton profil de cavalière (par exemple une photo avec ton cheval). La photo est stockée uniquement sur ton iPhone, elle n'est jamais envoyée à un serveur ni partagée avec des tiers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ce_que_tu_ressens_2.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.emiliecolli.EquiMood"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/ce_que_tu_ressens_2.png",
      "name": "EquiMood",
      "shortName": "EquiMood",
      "description": "Transforme tes émotions en confiance. Fais de ton mental ton plus grand allié.",
      "themeColor": "#C9A86A",
      "backgroundColor": "#FFFCF7"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0d6622e-ab44-435d-9ac8-581333dff2fa"
      }
    }
  }
}